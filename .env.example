# ─────────────────────────────────────────────────────────────
# GlaciaNav CRM — environment. Copy to `.env` and fill in.
# Never commit the real .env; only this template is tracked.
# ─────────────────────────────────────────────────────────────

# ── Database (used by the db service + the web app) ──
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=crm

# In production (docker compose) the app reaches Postgres over the compose
# network — docker-compose.yml sets DATABASE_URL to point at the `db` service,
# so you normally don't need to set it here. For local `npm run dev` against
# the dev database, use:
DATABASE_URL="postgresql://crm:change-me-strong-password@db:5432/crm"

# ── Session signing (REQUIRED) ──
# Generate with:  openssl rand -base64 32
SESSION_SECRET=replace-with-openssl-rand-base64-32

# ── Cloudflare Tunnel ──
# Create a tunnel in the Cloudflare Zero Trust dashboard, route your domain to
# http://web:3000, and paste the tunnel token here.
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ── Microsoft 365 SSO (optional) ──
# Register an app in Microsoft Entra ID with redirect URI:
#   https://YOUR-DOMAIN/api/auth/microsoft/callback
# and delegated scopes: openid, profile, email, User.Read.
# The client secret lives ONLY here — never in the database.
MS_ENABLED=false
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_ALLOWED_DOMAIN=
# (Enable/tenant/client id and allowed domain can also be set in the admin
#  console; env values here take precedence.)

# ── Deployment (optional overrides) ──
# WEB_IMAGE=ghcr.io/nimaema/glacianav_crm:latest
# WATCHTOWER_INTERVAL=60
# DOCKER_CONFIG_DIR=~/.docker
